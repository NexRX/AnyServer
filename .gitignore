backend/data/

# ═══════════════════════════════════════════════════════════════
#  Node / Frontend
# ═══════════════════════════════════════════════════════════════

# Dependencies
frontend/node_modules/
frontend/.pnpm

# Build output
frontend/dist/

# E2E Temp files
frontend/vite.config.test.ts.timestamp*

# E2E logs
frontend/e2e*.log

# Playwright
frontend/test-results/
frontend/playwright-report/
frontend/playwright/.cache/
frontend/blob-report/
frontend/.playwright/

# Test data artifacts
frontend/tshock/

# ═══════════════════════════════════════════════════════════════
#  Generated files (ts-rs TypeScript bindings)
# ═══════════════════════════════════════════════════════════════

# These are regenerated by `cargo test` in the backend.
# Uncomment the line below if you prefer to NOT commit them:
# frontend/src/types/generated/

# NOTE: backend/.sqlx/ is intentionally tracked (not ignored).
# It contains the SQLx offline query cache, which allows `cargo build`
# without a running database.  This is standard practice for SQLx projects.

